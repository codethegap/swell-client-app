{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "types": [
      "@cloudflare/vitest-pool-workers",
      "@cloudflare/vitest-pool-workers/types",
      "@swell/app-types",
      "vitest/globals"
    ]
  },
  "include": [
    "./**/*.ts",
    "../functions/**/*.ts"
  ],
  "exclude": [
    "../node_modules"
  ]
}
